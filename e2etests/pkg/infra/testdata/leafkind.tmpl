log file /etc/frr/frr.log debug

debug zebra events
debug zebra vxlan
debug bgp zebra
debug zebra events
debug zebra vxlan
debug bgp zebra
debug zebra events
debug zebra nht
debug zebra kernel
debug zebra rib
debug zebra nexthop
debug bgp neighbor-events
debug bgp updates
debug bgp keepalives
debug bgp nht
debug bgp zebra
debug bfd network
debug bfd peer
debug bfd zebra

router bgp {{ .ASN }}
 no bgp ebgp-requires-policy
 no bgp network import-check
 no bgp default ipv4-unicast

 neighbor {{ .SpineAddress }} remote-as {{ .SpineASN }}

{{- range .Neighbors }}
 neighbor {{ . }} remote-as {{ $.KindNodeASN }}
{{- if $.EnableBFD }}
 neighbor {{ . }} bfd
{{- end }}
{{- end }}

 !
 address-family ipv4 unicast
{{- if .RedistributeConnected }}
  redistribute connected
{{- end }}
  neighbor {{ .SpineAddress }} activate
{{- range .Neighbors }}
  neighbor {{ . }} activate
{{- end }}
 exit-address-family
 !
 address-family l2vpn evpn
  neighbor {{ .SpineAddress }} activate
{{- range .Neighbors }}
  neighbor {{ . }} activate
{{- end }}
  advertise-all-vni
  advertise-svi-ip
 exit-address-family
exit
!
