log file /etc/frr/frr.log debug

debug zebra events
debug zebra vxlan
debug bgp zebra
debug zebra nht
debug zebra kernel
debug zebra rib
debug zebra nexthop
debug bgp neighbor-events
debug bgp updates
debug bgp keepalives
debug bgp nht
debug bgp zebra
debug bfd network
debug bfd peer
debug bfd zebra
{{range .VRFs}}
vrf {{.Name}}
 vni {{.VNI}}
exit-vrf
{{end}}!
router bgp {{.BGP.ASN}}
 no bgp ebgp-requires-policy
 no bgp network import-check
 no bgp default ipv4-unicast
{{range .BGP.Peers}}
 neighbor {{.IPv4Address}} remote-as {{.ASN}}
{{- end}}
 !
 address-family ipv4 unicast
{{- range .BGP.Peers}}
  neighbor {{.IPv4Address}} activate
{{- end}}
  network {{.VTEPIP}}/32
 exit-address-family
 !
 address-family l2vpn evpn
{{- range .BGP.Peers}}
  neighbor {{.IPv4Address}} activate
{{- end}}
  advertise-all-vni
  advertise-svi-ip
 exit-address-family
exit
!
{{- range .VRFs}}
router bgp {{$.BGP.ASN}} vrf {{.Name}}
 !
 address-family ipv4 unicast
{{- if .RedistributeConnected}}
  redistribute connected
{{- end}}
 exit-address-family
 !
 address-family ipv6 unicast
{{- if .RedistributeConnected}}
  redistribute connected
{{- end}}
 exit-address-family
 !
 address-family l2vpn evpn
  advertise ipv4 unicast
  advertise ipv6 unicast
 exit-address-family
exit
!
{{end}}