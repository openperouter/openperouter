log file /etc/frr/frr.log debug
log timestamp precision 3
debug zebra events
debug zebra nht
debug zebra kernel
debug zebra rib
debug zebra nexthop
debug bgp neighbor-events
debug bgp updates
debug bgp keepalives
debug bgp nht
debug bgp zebra
debug bfd network
debug bfd peer
debug bfd zebra
hostname hostname
ip nht resolve-via-default
ipv6 nht resolve-via-default

route-map allowall permit 1
router bgp 64514
  no bgp ebgp-requires-policy
  no bgp network import-check
  no bgp default ipv4-unicast
  bgp router-id 10.0.0.2
  neighbor 192.168.11.2 remote-as 64512
  
  
  

  address-family ipv4 unicast
    neighbor 192.168.11.2 activate
    neighbor 192.168.11.2 allowas-in
  exit-address-family

  neighbor 192.169.10.3 remote-as 64515

  address-family ipv4 unicast
    network 192.169.10.3
    neighbor 192.169.10.3 activate
    neighbor 192.169.10.3 route-map allowall in
    neighbor 192.169.10.3 route-map allowall out
  exit-address-family

  address-family ipv4 unicast
    neighbor 192.169.10.3 activate
    neighbor 192.169.10.3 allowas-in
  exit-address-family

  neighbor 2001:db8:1::3 remote-as 64515

  address-family ipv6 unicast
    network 2001:db8:1::3/128
    neighbor 2001:db8:1::3 activate
    neighbor 2001:db8:1::3 route-map allowall in
    neighbor 2001:db8:1::3 route-map allowall out
  exit-address-family

  address-family ipv6 unicast
    neighbor 2001:db8:1::3 activate
    neighbor 2001:db8:1::3 allowas-in
  exit-address-family
  address-family ipv4 unicast
    network 100.65.0.1/32
  exit-address-family

  address-family l2vpn evpn
    neighbor 192.168.11.2 activate
    neighbor 192.168.11.2 allowas-in
    advertise-all-vni
    advertise-svi-ip
  exit-address-family
